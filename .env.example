# Environment variables — copy to `.env.local` for local-dev overrides.
# `.env.local` is gitignored; `.env.example` is committed as the contract.

# ─── Phase-5 LLM curation CLIs (Units 5.3 / 5.5 / 5.7-5.9; ADR-0008) ───
# Required for non-dry-run invocations of `pnpm ingest-arxiv` and
# `pnpm extract-leaderboard`. Defaults: undefined (force `--dry-run`).
# ANTHROPIC_API_KEY=sk-ant-...
# Optional per-machine daily spend cap (USD). Defaults: no cap.
# LLM_OPENPROBLEMS_DAILY_BUDGET_USD=5.00

# ─── Phase-6 Discussions (Q47 operational gate; ADR-0010) ───
# Server-side GitHub API token for the per-domain RSS digest's discussion
# items. Build-time only; never bundled into the client.
# GITHUB_TOKEN=ghp_...
# Public Giscus repo ID for the iframe wrapper. Set after Giscus.app config.
# NEXT_PUBLIC_GISCUS_REPO_ID=R_...

# ─── Phase-8 i18n (ADR-0011 + Unit 8.5) ───
# Canonical site URL override for preview deploys (Vercel, Netlify). Falls
# through to the production placeholder when unset. RSS / sitemap / citation
# blocks all consume this.
# NEXT_PUBLIC_SITE_URL=https://op-pr-123.vercel.app

# ─── Phase-9 Auth (Q54 operational gate; ADR-0012) ───
# GitHub OAuth app credentials. Register the app under the project GitHub
# org per Q54. Two apps recommended: one for production (Homepage =
# https://llm-openproblems.org, Callback = .../api/auth/callback/github);
# one for local dev (Homepage = http://localhost:3000, Callback =
# http://localhost:3000/api/auth/callback/github).
# Auth.js v5 canonical names: `AUTH_GITHUB_ID` + `AUTH_GITHUB_SECRET`
# (auto-detected by the `GitHub` provider without explicit config).
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
# NextAuth.js v5 requires a secret for JWT signing + CSRF tokens. Generate
# via `openssl rand -base64 32` or `npx auth secret`.
# AUTH_SECRET=

# ─── Phase-28 Auth multi-provider (Q73 operational gate; ADR-0020) ───
# Google OAuth credentials. Register the app in Google Cloud Console
# per Q73. Two apps recommended: one for production (Authorized JS
# origins = https://llm-openproblems.org, Authorized redirect URIs =
# .../api/auth/callback/google); one for local dev (Authorized JS
# origins = http://localhost:3000, Authorized redirect URIs =
# http://localhost:3000/api/auth/callback/google).
# Auth.js v5 canonical names: `AUTH_GOOGLE_ID` + `AUTH_GOOGLE_SECRET`
# (auto-detected by the `Google` provider without explicit config).
# When unset, the Google sign-in button surfaces an OAuth-configuration
# error on click; the GitHub sign-in button still works if its env vars
# are set (graceful degradation mirrors Q54 posture).
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# ─── Phase-9 Database (Q55 operational gate; ADR-0013) ───
# Turso database connection. Defaults to `file:./local.db` when unset
# (local dev). Production sets via Vercel env to the Turso libsql:// URL.
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# Auth token for Turso connections. Only required when TURSO_DATABASE_URL
# starts with `libsql://`. Generate via `turso db tokens create <db-name>`.
# TURSO_AUTH_TOKEN=

# ─── Phase-30 Subscriber-list email (Q75 operational gate; ADR-0021) ───
# Resend API key. Register at resend.com per Q75; verify the sender
# domain (DKIM + SPF + DMARC) on Resend's domain setup flow before
# production use. Free tier: 100/day + 3,000/month.
# When unset, the subscribe form returns "we couldn't send the email"
# (graceful degradation mirrors Q54 / Q73 posture per ADR-0021 D-G).
# RESEND_API_KEY=re_...
# Canonical RFC 5322 from-address (display name + email) for all
# transactional sends. Must be on a Resend-verified domain.
# EMAIL_FROM=LLM OpenProblems <digest@example.com>
