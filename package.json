{
  "name": "llm-openproblems",
  "version": "0.0.0",
  "private": true,
  "description": "A rated, taxonomy-organized encyclopedia of open problems in LLM and AI research. See MASTER_PROMPT.md.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22 <24"
  },
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "velite && next dev",
    "build": "velite && next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "velite": "velite",
    "velite:watch": "velite --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate-content": "tsx scripts/validate-content.ts",
    "audit-content": "tsx scripts/cross-link-audit.ts",
    "ingest-arxiv": "tsx scripts/ingest-arxiv.ts",
    "extract-leaderboard": "tsx scripts/extract-leaderboard.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "lhci": "lhci autorun",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "lint-staged": {
    "*.{ts,tsx,mts,cts,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@auth/drizzle-adapter": "^1.11.2",
    "@giscus/react": "^3.1.0",
    "@libsql/client": "^0.17.3",
    "@octokit/graphql": "^9.0.3",
    "@types/hast": "^3.0.4",
    "@vercel/blob": "^2.3.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "drizzle-orm": "^0.45.2",
    "fuse.js": "^7.3.0",
    "katex": "^0.16.46",
    "lucide-react": "^1.14.0",
    "next": "^15.0.0",
    "next-auth": "5.0.0-beta.31",
    "next-intl": "^3.26.5",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-katex": "^7.0.1",
    "rehype-pretty-code": "^0.14.3",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "sharp": "^0.34.5",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.6.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@lhci/cli": "^0.15.1",
    "@next/eslint-plugin-next": "^16.2.6",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "10.3.6",
    "@storybook/addon-onboarding": "10.3.6",
    "@storybook/addon-vitest": "10.3.6",
    "@storybook/nextjs-vite": "^10.3.6",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/d3-force": "^3.0.10",
    "@types/d3-selection": "^3.0.11",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "4.1.6",
    "@vitest/coverage-v8": "4.1.6",
    "diff": "^9.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-tailwindcss": "^3.18.3",
    "fast-xml-parser": "^5.8.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.60.0",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "storybook": "^10.3.6",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.59.3",
    "velite": "^0.3.1",
    "vite": "^8.0.13",
    "vitest": "^4.1.6",
    "yaml": "^2.9.0"
  }
}
